# AegisOS — Environment Configuration
# Copy this file to .env and fill in your API keys
# Never commit .env to version control

# ── LLM Provider API Keys ────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
CEREBRAS_API_KEY=your_cerebras_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# ── Model Selection (change only if you know what you are doing) ──
GROQ_MODEL=llama3-70b-8192
CEREBRAS_MODEL=llama3.1-70b
GEMINI_MODEL=gemini-1.5-flash

# ── Routing Strategy ─────────────────────────────────────
# Options: balanced | cheapest | fastest | smartest
AEGIS_ROUTE_MODE=balanced

# ── Mock Engine ───────────────────────────────────────────
# Seconds between threat events (float, min 1.0)
AEGIS_EVENT_INTERVAL=4.0

# ── Terminal Size ─────────────────────────────────────────
AEGIS_MIN_COLS=120
AEGIS_MIN_ROWS=30

# ── LLM Timeouts (seconds) ───────────────────────────────
AEGIS_LLM_TIMEOUT=15
AEGIS_GEMINI_TIMEOUT=20